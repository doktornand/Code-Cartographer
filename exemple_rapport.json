          "parameters": [],
          "return_type": null,
          "docstring": null,
          "source_code": "function Deploy-Application {\n    param([string]$AppName, [string]$PackagePath)\n    $attempt = 0\n    while ($attempt -lt $MaxRetries) {\n        $attempt++\n        try {\n            Publish-AzWebApp -ResourceGroupName $ResourceGroup `\n                -Name $AppName -ArchivePath $PackagePath -Force\n            $deployLog += \"SUCCESS: $AppName déployé à $timestamp\"\n            return $true\n        } catch {\n            if ($attempt -eq $MaxRetries) {\n                $deployLog += \"FAILED: $AppName après $MaxRetries tentatives\"\n                return $false\n            }\n            Start-Sleep -Seconds (2 * $attempt)\n        }\n    }\n}",
